Menu="OtherSettings"
Title="Docker DNS"
Icon="globe"
---
<link rel="stylesheet" href="/plugins/docker.dns/styles/docker-dns.css?v=2026.07.24">
<div id="docker-dns-settings">
  <form id="docker-dns-provider-form" onsubmit="return false">
    <fieldset>
      <legend>Synchronization</legend>
      <dl><dt>Enabled:</dt><dd><select id="docker-dns-enabled"><option value="false">No</option><option value="true">Yes</option></select></dd></dl>
      <dl><dt>DNS provider:</dt><dd><select id="docker-dns-provider"><option value="adguard">AdGuard Home</option><option value="pihole">Pi-hole v6</option></select></dd></dl>
      <dl><dt>API base URL:</dt><dd><input id="docker-dns-base-url" type="url" placeholder="http://192.168.1.2:3000" required></dd></dl>
      <dl id="docker-dns-username-row"><dt>Username:</dt><dd><input id="docker-dns-username" type="text" autocomplete="username"></dd></dl>
      <dl><dt>Password:</dt><dd><input id="docker-dns-password" type="password" autocomplete="new-password" placeholder="Leave empty to keep the stored password"></dd></dl>
      <dl><dt>Verify TLS certificates:</dt><dd><select id="docker-dns-verify-tls"><option value="true">Yes</option><option value="false">No</option></select></dd></dl>
      <dl><dt>Unraid IPv4 override:</dt><dd><input id="docker-dns-host-ip" type="text" inputmode="decimal" placeholder="Detected automatically"></dd></dl>
      <dl><dt>Request timeout:</dt><dd><input id="docker-dns-timeout" type="number" min="2" max="60" value="10"> seconds</dd></dl>
    </fieldset>
    <fieldset>
      <legend>Reverse Proxy</legend>
      <p class="docker-dns-help">Optional integration with a user-managed Caddy or Traefik container. Docker DNS only writes the generated <code>docker-dns</code> subdirectory inside the selected bind mount.</p>
      <dl><dt>Enabled:</dt><dd><select id="docker-dns-proxy-enabled"><option value="false">No</option><option value="true">Yes</option></select></dd></dl>
      <dl><dt>Adapter:</dt><dd><select id="docker-dns-proxy-adapter"><option value="caddy">Caddy v2</option><option value="traefik">Traefik v2/v3</option></select></dd></dl>
      <dl><dt>Proxy container:</dt><dd><select id="docker-dns-proxy-container"><option value="">Select a container</option></select></dd></dl>
      <dl><dt>LAN network:</dt><dd><select id="docker-dns-proxy-network"><option value="">Select a static-IP network</option></select></dd></dl>
      <dl><dt>Appdata bind mount:</dt><dd><select id="docker-dns-proxy-mount"><option value="">Select a writable bind mount</option></select><div id="docker-dns-proxy-mount-help" class="docker-dns-help"></div></dd></dl>
      <dl id="docker-dns-caddy-config-row"><dt>Main Caddyfile:</dt><dd><input id="docker-dns-caddy-config" type="text" value="/etc/caddy/Caddyfile"><div class="docker-dns-help">Add <code>import &lt;mount destination&gt;/docker-dns/*.caddy</code> to this file once.</div></dd></dl>
      <dl id="docker-dns-traefik-entrypoint-row"><dt>HTTP entrypoint:</dt><dd><input id="docker-dns-traefik-entrypoint" type="text" value="web"><div class="docker-dns-help">Configure Traefik's file provider to watch <code>&lt;mount destination&gt;/docker-dns</code>.</div></dd></dl>
    </fieldset>
    <div class="docker-dns-actions">
      <button type="button" id="docker-dns-save-settings">Save</button>
      <button type="button" id="docker-dns-test">Test Connection</button>
      <button type="button" id="docker-dns-validate-proxy">Validate Proxy</button>
      <button type="button" id="docker-dns-sync">Sync Now</button>
      <button type="button" id="docker-dns-cleanup">Cleanup All</button>
    </div>
  </form>
  <div id="docker-dns-status" class="docker-dns-status">Loading Docker DNS status…</div>
  <section class="docker-dns-container-section" aria-labelledby="docker-dns-container-heading">
    <header class="docker-dns-section-heading">
      <div>
        <h2 id="docker-dns-container-heading">Container List</h2>
        <p>Containers with published ports</p>
      </div>
      <span id="docker-dns-container-count" class="docker-dns-count" aria-live="polite"></span>
    </header>
    <div id="docker-dns-containers" class="docker-dns-container-list" aria-live="polite">
      <p class="docker-dns-empty">Loading…</p>
    </div>
  </section>
</div>
<script src="/plugins/docker.dns/javascript/docker-dns-settings.js?v=2026.07.24"></script>
